# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_user
DATABASE_PASSWORD=your_password
DATABASE_NAME=your_database
DATABASE_SYNCHRONIZE=true

# Server
PORT=3000
NODE_ENV=development

# Firebase Admin SDK (opcion recomendada)
GOOGLE_APPLICATION_CREDENTIALS=./firebase/serviceAccount.json
FIREBASE_PROJECT_ID=huellas-app-v-2

# Firebase Admin SDK (opcion alternativa por variables)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"



# SMTP (usado para enviar correos de verificacion personalizados)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=no-reply@huellas.com
SMTP_FROM_NAME=Revista Huellas

# Reconciliacion programada de verificacion (opcional)
USER_VERIFICATION_RECONCILE_ENABLED=false

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
